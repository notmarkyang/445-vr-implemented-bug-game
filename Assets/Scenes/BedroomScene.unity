  promptText: Interact
  bigSizeLines:
  - Ew, a bug.
  beforeTankInspectionLines:
  - '*Bug Noises*'
  afterTankBeforeBraceletLines:
  - '*Bug Noises*'
  afterBraceletBeforeTankBugLines:
  - That's a cute bracelet.
  - Can I have it?
  trainPhaseLines:
  - '*Bites lips*'
  - Where ya goin'.
  ventUnlockedLines:
  - I heard some screaming by the vents...
  - I'm too scared to check though
  stuckBugFoundLines:
  - Oh so it was just a lost traveller.
  hasScrewdriverLines:
  - Woah what is that?
  - Can I have it?
  finalPhaseLines:
  - Strange day today...
  fallbackLines:
  - '*Bug noises*'
