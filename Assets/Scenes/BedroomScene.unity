  m_Script: {fileID: 11500000, guid: 8d1f55725f416874f827bba5665c040e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::BugNPCInteractable
  promptText: Interact
  bigSizeLines:
  - Ew, a bug.
  beforeTankInspectionLines:
  - '*Bug Noises*'
  afterTankBeforeBraceletLines:
  - '*Bug Noises*'
  afterBraceletBeforeTankBugLines:
  - There's a ladybug by vent bed leg that'll take you up.
  - You just gotta grab onto her.
  - She doesn't talk much.
  trainPhaseLines:
  - There was a scuffle by the train earlier.
  - I wonder what that was about?
  ventUnlockedLines:
  - I heard some screaming by the vents...
  - I'm too scared to check though
  stuckBugFoundLines:
  - Hi.
  hasScrewdriverLines:
  - Woah what is that?
  - Can I have it?
  finalPhaseLines:
  - Strange day today...
  fallbackLines:
  - '*Bug noises*'
