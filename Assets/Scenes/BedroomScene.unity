  promptText: Interact
  bigSizeLines:
  - Ew, a bug.
  beforeTankInspectionLines:
  - '*Bug Noises*'
  afterTankBeforeBraceletLines:
  - '*Bug Noises*'
  afterBraceletBeforeTankBugLines:
  - That's a cute bracelet.
  - Can I have it?
  trainPhaseLines:
  - There was a scuffle by the train station earlier.
  - I wonder what that was about?
